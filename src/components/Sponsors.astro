---
// No active sponsors right now — show the support pitch and CTA only. When
// sponsors return, render them above the button.
---

<section id="sponsors" class="border-t border-catppuccin-surface0 bg-catppuccin-mantle/40">
  <div class="mx-auto max-w-3xl px-6 py-20 text-center">
    <p
      class="font-mono text-xs uppercase tracking-widest text-catppuccin-peach mb-3"
    >
      Sponsors
    </p>
    <h2
      class="text-3xl sm:text-4xl font-semibold tracking-tight text-catppuccin-text"
    >
      Support KDash.
    </h2>
    <p class="mt-4 text-catppuccin-subtext1">
      Sponsorship keeps KDash maintained and moving. If it saves you time,
      consider supporting its development.
    </p>

    <div class="mt-8">
      <a
        href="https://github.com/sponsors/deepu105"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md border border-catppuccin-mauve px-5 py-2.5 text-sm font-medium text-catppuccin-mauve hover:bg-catppuccin-mauve hover:text-catppuccin-crust transition"
      >
        <span aria-hidden="true">♥</span> Sponsor KDash
      </a>
    </div>
  </div>
</section>
